{
  "$$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "numInstances": 1,
    "restartPolictType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "startCommand": "node server.js"
  },
  "plugins": {
    "postgres": {
      "type": "postgresql"
    }
  }
}
